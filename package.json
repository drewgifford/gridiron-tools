{
  "name": "gridiron-tools",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun --bun next dev",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "lint": "biome check",
    "lint:fix": "biome check --write --unsafe",
    "format": "biome format --write",
    "typecheck": "bunx tsc --noEmit",
    "schema:generate": "drizzle-kit generate",
    "schema:migrate": "drizzle-kit migrate",
    "db:migrate": "bun run etc/scripts/migrate.ts",
    "db:seed": "bun run etc/scripts/seed.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.7",
    "@lucide/lab": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "obscenity": "^0.4.6",
    "postgres": "^3.4.9",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-latex-next": "^3.0.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
